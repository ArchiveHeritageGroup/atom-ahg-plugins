#!/bin/bash
set -e

cd "$(dirname "$0")/.."

TYPE=${1:-patch}
MSG=${2:-"Release update"}

# Read current version
CURRENT=$(grep -o '"version": "[^"]*"' version.json | cut -d'"' -f4)
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"

case $TYPE in
    major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
    minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
    patch) PATCH=$((PATCH + 1)) ;;
    *) echo "Usage: $0 [major|minor|patch] [message]"; exit 1 ;;
esac

NEW="${MAJOR}.${MINOR}.${PATCH}"
TAG="v${NEW}"
DATE=$(date +%Y-%m-%d)

# Update version.json
cat > version.json << EOF
{
    "version": "${NEW}",
    "name": "atom-extensions-catalog",
    "updated": "${DATE}"
}
EOF

echo "Releasing ${TAG}: ${MSG}"

git add -A
git commit -m "${TAG}: ${MSG}"
git tag -a "${TAG}" -m "${MSG}"
git push origin main
git push origin "${TAG}"

echo "✓ Released ${TAG}"
