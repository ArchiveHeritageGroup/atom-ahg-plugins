{
    "name": "DOI Integration",
    "machine_name": "ahgDoiPlugin",
    "version": "1.0.0",
    "description": "DOI integration via DataCite — mint, deactivate, sync, queue processing, badge display, and verification",
    "author": "The Archive and Heritage Group",
    "license": "GPL-3.0",
    "homepage": "https://theahg.co.za",
    "category": "integration",
    "keywords": ["doi", "datacite", "persistent-identifier", "mint", "digital-object-identifier"],
    "requires": {
        "atom_framework": ">=1.0.0",
        "atom": ">=2.8",
        "php": ">=8.1"
    },
    "dependencies": ["ahgCorePlugin"],
    "tables": [
        "ahg_doi",
        "ahg_doi_config",
        "ahg_doi_queue",
        "ahg_doi_mapping",
        "ahg_doi_log"
    ]
}
