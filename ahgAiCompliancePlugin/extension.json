{
    "name": "AI Compliance",
    "machine_name": "ahgAiCompliancePlugin",
    "version": "0.1.0",
    "description": "EU AI Act Article 12 record-keeping (PSIS port of ahg/ai-compliance). Tamper-evident receipt chain over every AI inference call using the ahg/inference-receipts library (SHA-256 chain + RFC 8785 JCS + Ed25519).",
    "author": "The Archive and Heritage Group",
    "license": "AGPL-3.0-or-later",
    "category": "ahg",
    "requires": {
        "atom_framework": ">=1.0.0",
        "atom": ">=2.8",
        "php": ">=8.2"
    },
    "dependencies": [
        "ahgCorePlugin"
    ],
    "composer": {
        "require": {
            "ahg/inference-receipts": "^0.1"
        }
    },
    "provides": {
        "services": [
            "InferenceLogger",
            "PropelChainStore",
            "KeyResolver",
            "SignerFactory"
        ],
        "tasks": [
            "ai-compliance:install-key",
            "ai-compliance:verify-inference-log",
            "ai-compliance:prune"
        ],
        "endpoints": [
            "/.well-known/ai-inference-pubkey"
        ]
    },
    "install_sql": "database/install.sql",
    "tables": [
        "ai_inference_log",
        "ai_inference_key"
    ]
}
