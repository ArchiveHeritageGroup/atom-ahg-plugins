    "requires": {
        "atom_framework": ">=1.0.0",
        "atom": ">=2.8",
        "php": ">=8.1"
    },
    "dependencies": ["ahgCorePlugin"],
    "tables": [
        "ahg_duplicate_detection",
        "ahg_duplicate_rule",
        "ahg_merge_log",
        "ahg_file_checksum",
        "ahg_dedupe_scan"
    ]
