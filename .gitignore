# Only track AHG plugins
/*
!/.gitignore
!/README.md
!/ahg*/
!/docs/

# Track the deploy helper so it ships with the repo (other bin/ scripts stay local).
!/bin/
/bin/*
!/bin/link-plugins.sh

# Dependencies and build artifacts
node_modules/
.sass-cache/
*.patch

# Backup and temporary files
.backups/
*.bak
*.bak.*
*.bak2
*.old
*.broken
*.qubit
*.snippets
*.orig
*.tmp
*~

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# PHP tools
.php-cs-fixer.cache
.phpunit.result.cache

# OS files
.DS_Store
Thumbs.db
!/testing/
!/.github/
